{
  "name": "@animeunion/api",
  "version": "0.18.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app-router": "./src/app-router.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "dev:newuser": "tsx watch --env-file-if-exists=../../.env.newuser src/index.ts",
    "start:e2e": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts",
    "seed": "tsx --env-file-if-exists=../../.env src/db/seed.ts"
  },
  "dependencies": {
    "@animeunion/shared": "*",
    "@fastify/cors": "^11.2.0",
    "@trpc/server": "^11.0.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "0.45.2",
    "fastify": "^5.2.0",
    "ffmpeg-static": "^5.2.0",
    "node-cron": "4.6.0",
    "pino": "^9.6.0",
    "undici": "7.28.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
