# ─────────────────────────────────────────────────────────────────────────────
# AnimeUnion Docker — template variabili d'ambiente
#
# Copia questo file in `.env` e compila i valori. Il file `.env` NON va MAI
# committato (è in .gitignore). I token API NON si mettono qui: vengono generati
# automaticamente al primo login e salvati in SQLite.
# ─────────────────────────────────────────────────────────────────────────────

# ── Credenziali AnimeUnion (OBBLIGATORIE) ────────────────────────────────────
# Registra un account gratuito su https://animeunion.tv/registrati
ANIMEUNION_EMAIL=tuaemail@esempio.com
ANIMEUNION_PASSWORD=la_tua_password

# ── API ──────────────────────────────────────────────────────────────────────
# Base URL delle API ufficiali AnimeUnion.
ANIMEUNION_API_URL=https://animeunion.tv/api/v1

# Source mode: api (produzione) | scraper (fallback) | mock (test offline).
SOURCE_MODE=api

# ── Storage ──────────────────────────────────────────────────────────────────
# Percorso del database SQLite (dentro al container).
DATABASE_PATH=/data/animeunion.db

# Percorso della libreria download (montato come volume).
DOWNLOAD_PATH=/anime

# ── Logging ──────────────────────────────────────────────────────────────────
# Livello pino: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
