{
  "name": "@animeunion/worker-desktop",
  "version": "0.18.0",
  "private": true,
  "description": "AnimeUnion Worker — app desktop Windows (GPU) per l'upscale neurale, con GUI, tray e collegamento automatico al NAS.",
  "author": "iCosiSenpai (https://github.com/iCosiSenpai)",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-main.mjs",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder --win --publish never",
    "release": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@animeunion/api": "*",
    "@animeunion/shared": "*",
    "@animeunion/worker": "*",
    "@trpc/client": "^11.0.0",
    "electron-updater": "6.3.9",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
  }
}
