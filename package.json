{
  "name": "animeunion-docker",
  "version": "0.1.1",
  "private": true,
  "description": "AnimeUnion Docker — applicazione ufficiale affiliata ad AnimeUnion per il download self-hosted degli anime.",
  "license": "AGPL-3.0-only",
  "author": "iCosiSenpai (https://github.com/iCosiSenpai)",
  "homepage": "https://github.com/iCosiSenpai/animeunion",
  "repository": {
    "type": "git",
    "url": "https://github.com/iCosiSenpai/animeunion.git"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:clean": "node scripts/free-ports.mjs && npm run dev",
    "dev:api": "npm run dev -w @animeunion/api",
    "dev:web": "npm run dev -w @animeunion/web",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run --passWithNoTests",
    "seed": "npm run seed -w @animeunion/api",
    "db:migrate": "npm run db:migrate -w @animeunion/api",
    "db:generate": "npm run db:generate -w @animeunion/api"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
